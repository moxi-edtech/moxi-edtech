  "private": true,
  "scripts": {
    "dev": "npm_config_registry=https://registry.npmjs.org/ npm_config_workspace= npm_config_workspaces= next dev",
    "build": "npm_config_registry=https://registry.npmjs.org/ npm_config_workspace= npm_config_workspaces= next build",
    "start": "npm_config_registry=https://registry.npmjs.org/ npm_config_workspace= npm_config_workspaces= next start",
    "lint": "npm_config_registry=https://registry.npmjs.org/ npm_config_workspace= npm_config_workspaces= eslint . --max-warnings 10000",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test --import tsx tests/unit/*.spec.ts",
    "test:integration": "node --test --import tsx tests/integration/*.spec.ts",
    "test:e2e:matrix": "node --test --import tsx tests/e2e/*.e2e.spec.ts",
    "test:unit:context": "node --test --import tsx tests/unit/context-regression.spec.ts",
    "test:unit:guards": "node --test --import tsx tests/unit/public-checkout-endpoint-guard.spec.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@moxi/auth-middleware": "workspace:*",
