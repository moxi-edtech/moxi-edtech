{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.klasse.ao"
        }
      ],
      "destination": "https://klasse.ao/:path*",
      "permanent": true
    },
    {
      "source": "/admissoes/:path*",
      "destination": "https://app.klasse.ao/admissoes/:path*",
      "permanent": false
    },
    {
      "source": "/ativar-acesso/:path*",
      "destination": "https://app.klasse.ao/ativar-acesso/:path*",
      "permanent": false
    },
    {
      "source": "/influencers/:path*",
      "destination": "https://app.klasse.ao/influencers/:path*",
      "permanent": false
    }
  ]
}
