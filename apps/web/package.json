{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "INNGEST_DEV=1 npm_config_registry=https://registry.npmjs.org/ npm_config_workspace= npm_config_workspaces= next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=6144 npm_config_registry=https://registry.npmjs.org/ npm_config_workspace= npm_config_workspaces= next build",
    "start": "npm_config_registry=https://registry.npmjs.org/ npm_config_workspace= npm_config_workspaces= next start",
    "lint": "npm_config_registry=https://registry.npmjs.org/ npm_config_workspace= npm_config_workspaces= eslint . --max-warnings 10000",
    "docker:build": "docker build -t moxi-edtech .",
    "docker:run": "docker run -p 3000:3000 moxi-edtech",
    "docker:compose": "docker-compose up",
    "docker:compose:build": "docker-compose up --build",
    "docker:compose:down": "docker-compose down",
    "docker:compose:logs": "docker-compose logs -f",
    "test": "echo 'No tests configured'",
    "test:unit:security": "node --test --import tsx tests/unit/activity-feed-security.spec.ts",
    "test:unit:fuzz": "node --test --import tsx tests/unit/fuzz-*.spec.ts tests/unit/curriculo-operacao.spec.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios"
  },
