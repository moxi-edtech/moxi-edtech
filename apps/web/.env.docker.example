# Copy to apps/web/.env.docker and fill in your project values.

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUPABASE_PUBLISHABLE_KEY>

# Optional server-side key for admin/seed endpoints
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>

# Convenience mirrors for server routes (optional)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<SUPABASE_PUBLISHABLE_KEY>
