{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.klasse.ao"
        }
      ],
      "destination": "https://klasse.ao/:path*",
      "permanent": true
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "app.klasse.ao"
        }
      ],
      "destination": "/redirect",
      "permanent": false
    }
  ]
}
