{
  "crons": [
    {
      "path": "/api/jobs/subscriptions/reminders",
      "schedule": "0 8 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.klasse.ao"
        }
      ],
      "destination": "https://klasse.ao/:path*",
      "permanent": true
    }
  ]
}
